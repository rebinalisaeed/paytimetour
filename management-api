<!DOCTYPE html>
<html lang="ckb" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>API / Integration - Pay Time Tour</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        body { font-family: 'Noto Sans Arabic', sans-serif; background: #dce8f8; padding: 20px; direction: rtl; }
        .container { max-width: 800px; margin: 0 auto; }
        .header { background: #2d4a7a; color: white; padding: 15px 20px; border-radius: 10px 10px 0 0; display: flex; justify-content: space-between; align-items: center; }
        .header h1 { font-size: 20px; }
        .back-btn { background: #d32f2f; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-size: 14px; text-decoration: none; }
        .back-btn:hover { background: #b71c1c; }
        .content { background: white; padding: 25px; border-radius: 0 0 10px 10px; }
        .silver-box { background: #e8e8e8; border: 1px solid #ccc; border-radius: 8px; padding: 20px; margin-bottom: 20px; }
        .info-row { display: flex; margin-bottom: 15px; align-items: center; flex-wrap: wrap; }
        .info-label { width: 160px; font-weight: 700; color: #2d4a7a; }
        .info-value { flex: 1; }
        .info-value input, .info-value select { width: 100%; max-width: 300px; padding: 8px; border: 1px solid #ccc; border-radius: 5px; }
        .api-key { font-family: monospace; background: white; padding: 5px; border-radius: 3px; }
        .regenerate-btn { background: #ff9800; color: white; border: none; padding: 5px 12px; border-radius: 3px; cursor: pointer; }
        .save-btn { background: #2e7d32; color: white; border: none; padding: 10px 25px; border-radius: 6px; cursor: pointer; margin-top: 10px; }
        h3 { color: #2d4a7a; margin-bottom: 15px; border-right: 4px solid #2d4a7a; padding-right: 10px; }
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>🔌 API / Integration</h1>
        <a href="index.html" class="back-btn">◀ گەڕانەوە بۆ سەرەکی</a>
    </div>
    <div class="content">
        <div class="silver-box">
            <h3>🔑 کلیلی API (API Key)</h3>
            <div class="info-row"><div class="info-label">API Key:</div><div class="info-value"><span id="apiKeyDisplay" class="api-key"></span> <button class="regenerate-btn" onclick="regenerateApiKey()">🔄 نوێکردنەوە</button></div></div>
            <div class="info-row"><div class="info-label">API Secret:</div><div class="info-value"><span id="apiSecretDisplay" class="api-key"></span></div></div>
        </div>
        
        <div class="silver-box">
            <h3>🌐 Integration Settings</h3>
            <div class="info-row"><div class="info-label">Webhook URL:</div><div class="info-value"><input type="url" id="webhookUrl" placeholder="https://your-server.com/webhook"></div></div>
            <div class="info-row"><div class="info-label">Integration فعالە:</div><div class="info-value"><input type="checkbox" id="integrationEnabled"></div></div>
            <div class="info-row"><div class="info-label">ناردنی داتا بۆ سرڤەری دەرەکی:</div><div class="info-value"><input type="checkbox" id="autoSync"></div></div>
        </div>
        
        <div class="silver-box">
            <h3>📡 API Endpoints</h3>
            <div class="info-row"><div class="info-label">GET /api/employees:</div><div class="info-value"><code>هێنانی هەموو کارمەندان</code></div></div>
            <div class="info-row"><div class="info-label">GET /api/attendance:</div><div class="info-value"><code>هێنانی تۆمارەکانی هاتن و دەرچوون</code></div></div>
            <div class="info-row"><div class="info-label">POST /api/attendance/checkin:</div><div class="info-value"><code>تۆمارکردنی هاتن</code></div></div>
            <div class="info-row"><div class="info-label">POST /api/attendance/checkout:</div><div class="info-value"><code>تۆمارکردنی دەرچوون</code></div></div>
        </div>
        
        <button class="save-btn" onclick="saveApiSettings()">💾 پاشەکەوتکردن</button>
    </div>
</div>

<script>
    function generateRandomString(length) {
        return Math.random().toString(36).substring(2, 2 + length) + Date.now().toString(36);
    }
    
    function loadApiSettings() {
        const settings = JSON.parse(localStorage.getItem('apiSettings') || '{}');
        document.getElementById('apiKeyDisplay').innerText = settings.apiKey || '—';
        document.getElementById('apiSecretDisplay').innerText = settings.apiSecret || '—';
        document.getElementById('webhookUrl').value = settings.webhookUrl || '';
        document.getElementById('integrationEnabled').checked = settings.integrationEnabled || false;
        document.getElementById('autoSync').checked = settings.autoSync || false;
        
        if (!settings.apiKey) regenerateApiKey();
    }
    
    function regenerateApiKey() {
        const newKey = 'pk_' + generateRandomString(24);
        const newSecret = 'sk_' + generateRandomString(32);
        document.getElementById('apiKeyDisplay').innerText = newKey;
        document.getElementById('apiSecretDisplay').innerText = newSecret;
        
        const settings = JSON.parse(localStorage.getItem('apiSettings') || '{}');
        settings.apiKey = newKey;
        settings.apiSecret = newSecret;
        localStorage.setItem('apiSettings', JSON.stringify(settings));
        alert('API Key و Secret نوێ کرانەوە!');
    }
    
    function saveApiSettings() {
        const settings = JSON.parse(localStorage.getItem('apiSettings') || '{}');
        settings.webhookUrl = document.getElementById('webhookUrl').value;
        settings.integrationEnabled = document.getElementById('integrationEnabled').checked;
        settings.autoSync = document.getElementById('autoSync').checked;
        settings.updatedAt = new Date().toISOString();
        
        localStorage.setItem('apiSettings', JSON.stringify(settings));
        alert('✅ ڕێکخستنەکانی API پاشەکەوت کرا!');
    }
    
    loadApiSettings();
</script>
</body>
</html>
